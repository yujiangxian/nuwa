# Frontend Vite environment (copy to `.env.local`)

# Must match backend NUWA_API_KEY when that is set
# VITE_NUWA_API_KEY=change-me

# Default axios timeout in ms (optional; settings backendUrl still overrides base URL)
# VITE_API_TIMEOUT_MS=60000

# Long-running requests (TTS / agent stream) timeout in ms (default: 300000)
# VITE_API_LONG_TIMEOUT_MS=300000
