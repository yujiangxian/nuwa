# Backend / process environment (copy to `.env` or export in shell)
# Frontend Vite vars belong in `app/web/.env.local` — see `app/web/.env.example`.

# Bind address (default: loopback only)
NUWA_HOST=127.0.0.1
NUWA_PORT=8080

# Optional API key — when set, all non-GET requests require header X-Api-Key
# NUWA_API_KEY=change-me

# Comma-separated CORS origins (default: http://localhost:5173)
# NUWA_ALLOWED_ORIGINS=http://localhost:5173

# Max concurrent ASR/TTS inference jobs (default: 2)
# NUWA_INFERENCE_CONCURRENCY=2

# TTS output retention in days (default: 7)
# NUWA_TTS_RETENTION_DAYS=7

# Override config.json path
# NUWA_CONFIG=/path/to/config.json

# Ollama endpoints (defaults derive tags from chat URL)
# OLLAMA_CHAT_URL=http://localhost:11434/api/chat
# OLLAMA_TAGS_URL=http://localhost:11434/api/tags
