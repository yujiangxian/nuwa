#!/bin/sh
# Global commit-msg hook: remove AI Co-authored-by trailers (Cursor / Claude / Copilot).
HOOK_DIR=$(dirname "$0")
if command -v python >/dev/null 2>&1; then
  python "$HOOK_DIR/strip-ai-coauthor.py" "$1"
elif command -v python3 >/dev/null 2>&1; then
  python3 "$HOOK_DIR/strip-ai-coauthor.py" "$1"
fi
